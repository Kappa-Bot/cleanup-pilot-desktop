{
  "name": "cleanup-pilot-desktop",
  "version": "0.1.0",
  "description": "Windows cleanup and storage insights desktop app",
  "main": "dist-electron/main.js",
  "license": "MIT",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:renderer\" \"npm:dev:main\" \"npm:dev:electron\"",
    "dev:renderer": "vite",
    "dev:main": "tsc -p tsconfig.electron.json --watch",
    "dev:electron": "wait-on tcp:5173 file:dist-electron/main.js && node scripts/run-electron-dev.cjs",
    "build": "npm run build:renderer && npm run build:main",
    "build:renderer": "vite build",
    "build:main": "tsc -p tsconfig.electron.json",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.electron.json --noEmit",
    "test": "jest --runInBand",
    "test:e2e": "playwright test",
    "benchmark": "node benchmark/runBenchmarks.cjs"
  },
  "dependencies": {
    "@playwright/test": "^1.58.2",
    "axios": "^1.13.5",
    "electron-store": "^8.2.0",
    "playwright": "^1.58.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sql.js": "^1.14.0",
    "uplot": "^1.6.32",
    "zod": "^4.3.6",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@swc/core": "^1.15.11",
    "@swc/jest": "^0.2.39",
    "@testing-library/react": "^14.2.1",
    "@types/jest": "^29.5.12",
    "@types/node": "^18.19.130",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "@types/sql.js": "^1.4.9",
    "@vitejs/plugin-react": "^4.2.1",
    "concurrently": "^8.2.2",
    "electron": "^25.9.8",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "jsdom": "^22.1.0",
    "ts-jest": "^29.1.2",
    "typescript": "^5.4.5",
    "vite": "^4.5.5",
    "wait-on": "^7.2.0"
  }
}
